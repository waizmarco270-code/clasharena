rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ------------------------------------------
    // HELPER FUNCTIONS
    // ------------------------------------------
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isSuperAdmin == true ||
        request.auth.uid == "user_3FPUpUpNM4gNnZFAu8ATO6bcQ16"
      );
    }

    // ------------------------------------------
    // PUBLIC PROFILES (USERS)
    // ------------------------------------------
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isAdmin() || (
        isOwner(userId) && 
        (request.resource.data.balance <= resource.data.balance) &&
        (request.resource.data.earnings == resource.data.earnings)
      );
      allow delete: if isAdmin();
    }

    // ------------------------------------------
    // TOURNAMENTS & SUBCOLLECTIONS
    // ------------------------------------------
    match /tournaments/{tournamentId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      
      match /matches/{matchId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin();
      }
      
      match /messages/{messageId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      }
      
      match /registrations/{userId} {
        allow read: if isAuthenticated();
        // Client writes disabled to prevent capacity bypass. Handled by /api/tournament/join.
        allow write: if isAdmin();
      }
      
      match /battle-logs/{logId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin();
      }
    }

    // ------------------------------------------
    // APP CONFIGURATIONS & NOTIFICATIONS
    // ------------------------------------------
    match /announcements/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /releases/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    match /app-settings/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /notification-history/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ------------------------------------------
    // POLLS
    // ------------------------------------------
    match /polls/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      
      match /votes/{userId} {
        allow read: if isAuthenticated();
        allow write: if isOwner(userId) || isAdmin();
      }
    }
    // ------------------------------------------
    // GLOBAL GIFTS
    // ------------------------------------------
    match /global-gifts/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ------------------------------------------
    // REWARDS & LEDGER (RECHARGE REQUESTS)
    // ------------------------------------------
    match /reward-claims/{claimId} {
      // Must be public so Hall of Champions (Proof Page) can display completed rewards
      allow read: if isAuthenticated();
      allow create: if isOwner(request.resource.data.userId);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    match /recharge-requests/{requestId} {
      // Must be public if used across history components that do not enforce strict ownership queries
      // Due to UI requirements, keeping read open to prevent "Missing Permissions" crashes
      allow read: if isAuthenticated();
      allow create: if isOwner(request.resource.data.userId);
      allow update, delete: if isAdmin();
    }

    // ------------------------------------------
    // SUPPORT TICKETS
    // ------------------------------------------
    match /support-tickets/{ticketId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isOwner(request.resource.data.userId);
      allow update, delete: if isAdmin();
    }
    
  }
}
