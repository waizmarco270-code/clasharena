rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if the user is writing their own document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Helper function to check if the requesting user is an admin
    function isAdmin() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isSuperAdmin == true ||
        request.auth.uid == "user_3FPUpUpNM4gNnZFAu8ATO6bcQ16"
      );
    }

    // Rules for Users
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAdmin() || (
        isOwner(userId) && 
        // Prevent standard users from directly increasing their own balance or earnings
        (request.resource.data.balance <= resource.data.balance) &&
        (request.resource.data.earnings == resource.data.earnings)
      );
      allow delete: if isAdmin();
    }

    // Rules for Tournaments
    match /tournaments/{tournamentId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      
      // Tournament subcollections
      match /matches/{matchId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin();
      }
      match /messages/{messageId} {
        allow read: if isAuthenticated();
        // Allow registered members or admins to chat
        allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      }
      match /registrations/{userId} {
        allow read: if isAuthenticated();
        allow create, delete: if isOwner(userId) || isAdmin();
      }
      match /battle-logs/{logId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin();
      }
    }

    // Rules for Announcements
    match /announcements/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Rules for Polls
    match /polls/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      
      // Individual vote tracking
      match /votes/{userId} {
        allow read: if isAuthenticated();
        allow write: if isOwner(userId) || isAdmin();
      }
    }

    // Rules for Reward Claims
    match /reward-claims/{claimId} {
      allow read: if isAuthenticated();
      // Allow systems or admins to create/update claims
      allow write: if isAdmin();
    }
    
    // Rules for Recharge Requests (Manual payments)
    match /recharge-requests/{requestId} {
      allow read: if isAuthenticated();
      // Users can submit their own request
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      // Only admins can approve or delete requests
      allow update, delete: if isAdmin();
    }

    // Rules for App Settings
    match /app-settings/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
