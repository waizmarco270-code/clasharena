
{
  "entities": {
    "Tournament": {
      "title": "Tournament",
      "description": "Represents a Clash of Clans tournament event. Updated for arena system.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["paid", "free", "championship"] },
        "subCategory": { "type": "string", "enum": ["knockout", "1vs1", "tdm"] },
        "entryFee": { "type": "number" },
        "prizePool": { "type": "string" },
        "currentPlayers": { "type": "number" },
        "maxPlayers": { "type": "number" },
        "townHall": { "type": "number", "description": "Required Town Hall level (0 for None)" },
        "startTime": { "type": "string", "format": "date-time" },
        "registrationStartTime": { "type": "string", "format": "date-time" },
        "registrationEndTime": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["upcoming", "open", "full", "ongoing", "completed"] },
        "imageUrl": { "type": "string" },
        "rules": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["name", "type", "subCategory", "entryFee", "maxPlayers", "status", "startTime", "registrationStartTime", "registrationEndTime"]
    },
    "TournamentRegistration": {
      "title": "Tournament Registration",
      "description": "A record of a user registering for a tournament.",
      "type": "object",
      "properties": {
        "tournamentId": { "type": "string" },
        "userId": { "type": "string" },
        "username": { "type": "string" },
        "tag": { "type": "string" },
        "registeredAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tournamentId", "userId", "username", "tag", "registeredAt"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user statistics and account information.",
      "type": "object",
      "properties": {
        "username": { "type": "string" },
        "tag": { "type": "string" },
        "townHall": { "type": "number" },
        "avatarUrl": { "type": "string" },
        "rank": { "type": "string" },
        "balance": { "type": "number" },
        "wins": { "type": "number" },
        "losses": { "type": "number" },
        "earnings": { "type": "number" },
        "upiId": { "type": "string" },
        "upiQrUrl": { "type": "string" },
        "profileLockedUntil": { "type": "string", "format": "date-time" },
        "isAdmin": { "type": "boolean" },
        "isSuperAdmin": { "type": "boolean" }
      },
      "required": ["username", "tag", "townHall", "balance"]
    },
    "RechargeRequest": {
      "title": "Recharge Request",
      "description": "A request for a manual balance top-up.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "username": { "type": "string" },
        "amount": { "type": "number" },
        "transactionId": { "type": "string" },
        "screenshotUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "rejectionReason": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "transactionId", "screenshotUrl", "status"]
    },
    "AppSettings": {
      "title": "App Settings",
      "description": "Global application configuration including dynamic backgrounds.",
      "type": "object",
      "properties": {
        "backgrounds": {
          "type": "object",
          "properties": {
            "arena": { "type": "string" },
            "dashboard": { "type": "string" },
            "wallet": { "type": "string" },
            "hallOfChampions": { "type": "string" }
          }
        },
        "payment": {
          "type": "object",
          "properties": {
            "adminUpiId": { "type": "string" },
            "adminQrUrl": { "type": "string" }
          }
        }
      }
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/tournaments/{tournamentId}": {
      "schema": "Tournament",
      "description": "Public list of all available and past tournaments."
    },
    "/tournaments/{tournamentId}/registrations/{userId}": {
      "schema": "TournamentRegistration",
      "description": "User registrations for a specific tournament."
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Private user profiles."
    },
    "/recharge-requests/{requestId}": {
      "schema": "RechargeRequest",
      "description": "Pending and past manual recharge requests."
    },
    "/app-settings/{settingId}": {
      "schema": "AppSettings",
      "description": "Global settings for the application."
    }
  }
}
