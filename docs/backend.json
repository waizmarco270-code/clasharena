
{
  "entities": {
    "Tournament": {
      "title": "Tournament",
      "description": "Represents a Clash of Clans tournament event.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "entryFee": { "type": "number" },
        "prizePool": { "type": "number" },
        "currentPlayers": { "type": "number" },
        "maxPlayers": { "type": "number" },
        "startTime": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["open", "full", "ongoing", "completed"] },
        "imageUrl": { "type": "string" }
      },
      "required": ["name", "category", "entryFee", "prizePool", "maxPlayers", "status"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user statistics and account information.",
      "type": "object",
      "properties": {
        "username": { "type": "string" },
        "tag": { "type": "string" },
        "townHall": { "type": "number" },
        "avatarUrl": { "type": "string" },
        "rank": { "type": "string" },
        "balance": { "type": "number" },
        "wins": { "type": "number" },
        "losses": { "type": "number" },
        "earnings": { "type": "number" },
        "upiId": { "type": "string" },
        "upiQrUrl": { "type": "string" },
        "profileLockedUntil": { "type": "string", "format": "date-time" },
        "isAdmin": { "type": "boolean" },
        "isSuperAdmin": { "type": "boolean" }
      },
      "required": ["username", "tag", "townHall", "balance"]
    },
    "RechargeRequest": {
      "title": "Recharge Request",
      "description": "A request for a manual balance top-up.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "username": { "type": "string" },
        "amount": { "type": "number" },
        "transactionId": { "type": "string" },
        "screenshotUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "rejectionReason": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "transactionId", "screenshotUrl", "status"]
    },
    "MatchRecord": {
      "title": "Match Record",
      "description": "Represents a single match result for verification.",
      "type": "object",
      "properties": {
        "tournamentId": { "type": "string" },
        "player1Id": { "type": "string" },
        "player2Id": { "type": "string" },
        "reportedScore": { "type": "string" },
        "screenshotUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "verified", "mismatch", "failed"] }
      },
      "required": ["tournamentId", "player1Id", "player2Id", "status"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/tournaments/{tournamentId}": {
      "schema": "Tournament",
      "description": "Public list of all available and past tournaments."
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Private user profiles."
    },
    "/recharge-requests/{requestId}": {
      "schema": "RechargeRequest",
      "description": "Pending and past manual recharge requests."
    },
    "/matches/{matchId}": {
      "schema": "MatchRecord",
      "description": "Match records for verification."
    }
  }
}
