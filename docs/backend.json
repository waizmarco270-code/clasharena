
{
  "entities": {
    "Tournament": {
      "title": "Tournament",
      "description": "Represents a Clash of Clans tournament event. Updated for arena system with advanced rewards.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["paid", "free", "championship"] },
        "subCategory": { "type": "string", "enum": ["knockout", "1vs1", "tdm"] },
        "entryFee": { "type": "number" },
        "rewardType": { "type": "string", "enum": ["money", "coin", "item"] },
        "rewardValue": { "type": "string" },
        "rewardItemName": { "type": "string" },
        "rewardImageUrl": { "type": "string" },
        "prizePool": { "type": "string" },
        "currentPlayers": { "type": "number" },
        "maxPlayers": { "type": "number" },
        "townHall": { "type": "number" },
        "startTime": { "type": "string", "format": "date-time" },
        "registrationStartTime": { "type": "string", "format": "date-time" },
        "registrationEndTime": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["upcoming", "open", "full", "ongoing", "completed"] },
        "imageUrl": { "type": "string" },
        "rules": { "type": "array", "items": { "type": "string" } },
        "clanLink": { "type": "string" },
        "clanUid": { "type": "string" },
        "winnerId": { "type": "string" },
        "winnerName": { "type": "string" }
      },
      "required": ["name", "type", "subCategory", "entryFee", "maxPlayers", "status", "startTime", "registrationStartTime", "registrationEndTime", "rewardType"]
    },
    "Announcement": {
      "title": "Announcement",
      "description": "Global app announcements.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string", "enum": ["info", "war", "payout", "system"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Poll": {
      "title": "Poll",
      "description": "Community voting polls with aggregated results for efficiency.",
      "type": "object",
      "properties": {
        "question": { "type": "string" },
        "options": { "type": "array", "items": { "type": "string" } },
        "voteCounts": { "type": "object", "description": "Mapping of option index to vote count" },
        "totalVotes": { "type": "number" },
        "allowMultiple": { "type": "boolean" },
        "displayMode": { "type": "string", "enum": ["percentage", "number"] },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "TournamentMatch": {
      "title": "Tournament Match",
      "description": "A single match within a tournament bracket.",
      "type": "object",
      "properties": {
        "round": { "type": "number" },
        "matchIndex": { "type": "number" },
        "player1Id": { "type": "string" },
        "player2Id": { "type": "string" },
        "player1Name": { "type": "string" },
        "player2Name": { "type": "string" },
        "winnerId": { "type": "string" },
        "nextMatchId": { "type": "string" }
      }
    },
    "TournamentMessage": {
      "title": "Tournament Message",
      "description": "Chat message within a tournament arena.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "username": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "text": { "type": "string" },
        "isPinned": { "type": "boolean" },
        "isAdmin": { "type": "boolean" },
        "isSuperAdmin": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "TournamentRegistration": {
      "title": "Tournament Registration",
      "description": "A record of a user registering for a tournament.",
      "type": "object",
      "properties": {
        "tournamentId": { "type": "string" },
        "userId": { "type": "string" },
        "username": { "type": "string" },
        "tag": { "type": "string" },
        "registeredAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tournamentId", "userId", "username", "tag", "registeredAt"]
    },
    "BattleLog": {
      "title": "Battle Log",
      "description": "Screenshot and caption of a match battle.",
      "type": "object",
      "properties": {
        "imageUrl": { "type": "string" },
        "caption": { "type": "string" },
        "uploadedBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "RewardClaim": {
      "title": "Reward Claim",
      "description": "A request/record for a tournament reward fulfillment.",
      "type": "object",
      "properties": {
        "tournamentId": { "type": "string" },
        "tournamentName": { "type": "string" },
        "userId": { "type": "string" },
        "username": { "type": "string" },
        "rewardType": { "type": "string" },
        "rewardValue": { "type": "string" },
        "rewardItemName": { "type": "string" },
        "rewardImageUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "completed"] },
        "proofImageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" }
      }
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "User statistics and account information.",
      "type": "object",
      "properties": {
        "username": { "type": "string" },
        "tag": { "type": "string" },
        "townHall": { "type": "number" },
        "avatarUrl": { "type": "string" },
        "balance": { "type": "number" },
        "earnings": { "type": "number" },
        "wins": { "type": "number" },
        "tournamentsPlayed": { "type": "number" },
        "isAdmin": { "type": "boolean" },
        "isSuperAdmin": { "type": "boolean" },
        "isHidden": { "type": "boolean" },
        "lastActive": { "type": "string", "format": "date-time" },
        "lastReadNotificationsAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/tournaments/{tournamentId}": {
      "schema": "Tournament",
      "description": "Public collection of tournaments."
    },
    "/announcements/{id}": {
      "schema": "Announcement",
      "description": "Global announcements."
    },
    "/polls/{id}": {
      "schema": "Poll",
      "description": "Community polls."
    },
    "/polls/{id}/votes/{userId}": {
      "schema": "object",
      "description": "Individual user votes for historical tracking."
    },
    "/tournaments/{tournamentId}/matches/{matchId}": {
      "schema": "TournamentMatch",
      "description": "Tournament bracket matches."
    },
    "/tournaments/{tournamentId}/messages/{messageId}": {
      "schema": "TournamentMessage",
      "description": "Real-time arena chat."
    },
    "/tournaments/{tournamentId}/registrations/{userId}": {
      "schema": "TournamentRegistration",
      "description": "User registrations."
    },
    "/tournaments/{tournamentId}/battle-logs/{logId}": {
      "schema": "BattleLog",
      "description": "Public battlefield screenshots."
    },
    "/reward-claims/{claimId}": {
      "schema": "RewardClaim",
      "description": "Victory proof ledger."
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles."
    }
  }
}
